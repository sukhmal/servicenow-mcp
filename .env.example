# ServiceNow instance URL (no trailing slash)
# Example: https://dev12345.service-now.com
SERVICENOW_INSTANCE_URL=https://devXXXXX.service-now.com

# ServiceNow credentials (Basic Auth)
# The user needs appropriate roles for the modules you want to access.
# For full access, use an admin account or a user with: admin, rest_api_explorer,
# web_service_admin, itil, catalog_admin, sn_appclient.app_client_company_installer
SERVICENOW_USERNAME=admin
SERVICENOW_PASSWORD=your-password-here

# Server mode: "debug" or "develop"
#   debug   — (default) Read-only. 88 tools for safe investigation and debugging.
#   develop — Read-write. 105 tools including create, update, and delete operations.
SERVICENOW_MODE=debug
